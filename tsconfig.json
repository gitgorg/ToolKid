{
    "compilerOptions": {
        "outDir": "./compiled",
        "module": "commonJS",
        "alwaysStrict": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": true,
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "noUnusedLocals": true,
        "strictNullChecks": true,
        "types": ["node"],
        "target": "ES2021",
        "sourceMap": true,
    },
    "exclude": [
        "node_modules"
    ]
}